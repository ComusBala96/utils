{
    "name": "@orians/utils",
    "version": "2.0.0",
    "homepage": "https://github.com/ComusBala96/utils.git",
    "description": "A npm package of utils for orians.",
    "type": "module",
    "main": "cjs/index.js",
    "module": "esm/index.js",
    "types": "esm/index.d.ts",
    "exports": {
        ".": {
            "require": "./cjs/index.js",
            "import": "./esm/index.js",
            "types": "./esm/index.d.ts"
        },
        "./plugins": {
            "require": "./cjs/css/plugins.css",
            "import": "./esm/css/plugins.css"
        },
        "./select2.min.css": {
            "require": "./cjs/css/select2.min.css",
            "import": "./esm/css/select2.min.css"
        }
    },
    "license": "MIT",
    "keywords": [
        "orians",
        "npm",
        "@orians",
        "@orians/utils",
        "utils"
    ],
    "author": {
        "name": "OrianSoft",
        "email": "info@oriansoft.com"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/ComusBala96/utils.git"
    },
    "publishConfig": {
        "registry": "https://npm.pkg.github.com"
    },
    "scripts": {
        "clean": "rm -rf esm cjs",
        "build:esm": "tsc -p tsconfig.esm.json",
        "build:cjs": "tsc -p tsconfig.cjs.json",
        "build:esm:watch": "tsc -p tsconfig.esm.json --watch",
        "build:cjs:watch": "tsc -p tsconfig.cjs.json --watch",
        "build:css": "cpy \"src/**/*.css\" esm --parents && cpy \"src/**/*.css\" cjs --parents",
        "build:css:watch": "npm run build:css && chokidar \"src/**/*.{css}\" -c",
        "build:ets": "cpy \"src/**/*.d.ts\" esm --parents && cpy \"src/**/*.d.ts\" cjs --parents",
        "build:ets:watch": "npm run build:ets && chokidar \"src/**/*.{d.ts}\" -c",
        "build": "npm run clean && npm run build:esm && npm run build:cjs && npm run build:css",
        "dev": "npm run clean && concurrently -k -n ESM,CJS,CSS \"npm:build:esm:watch\" \"npm:build:cjs:watch\" \"npm:build:css:watch\" "
    },
    "dependencies": {
        "datatables.net-buttons-dt": "^3.2.4",
        "datatables.net-dt": "^2.3.2",
        "datatables.net-responsive-dt": "^3.0.5",
        "datatables.net-searchbuilder-dt": "^1.8.3",
        "datatables.net-searchpanes-dt": "^2.3.4",
        "datatables.net-select-dt": "^3.0.1",
        "highcharts": "^12.2.0",
        "jodit": "^4.6.2",
        "moment": "^2.30.1",
        "pdfmake": "^0.3.7",
        "summernote": "^0.9.1",
        "sweetalert2": "^11.15.3",
        "swiper": "^11.2.6",
        "select2": "^4.1.0-rc.0",
        "jquery-datetimepicker": "^2.5.21",
        "xlsx": "^0.18.5"
    },
    "devDependencies": {
        "@types/select2": "^4.0.63",
        "jquery": "^4.0.0",
        "jquery-confirm": "^3.3.4",
        "jquery-datetimepicker": "^2.5.21",
        "jquery-validation": "^1.21.0",
        "@typescript-eslint/eslint-plugin": "^8.57.1",
        "@typescript-eslint/parser": "^8.57.1",
        "@types/node": "^25.5.0",
        "chokidar-cli": "^3.0.0",
        "concurrently": "^9.2.1",
        "cpy-cli": "^7.0.0",
        "eslint": "^9.39.4",
        "eslint-config-prettier": "^9.1.0",
        "eslint-plugin-prettier": "^5.1.3",
        "eslint-plugin-react": "^7.34.3",
        "eslint-plugin-react-hooks": "^5.1.0",
        "prettier": "^3.3.2",
        "typescript": "^5.9.3"
    }
}
